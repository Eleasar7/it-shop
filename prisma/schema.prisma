// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ═══════════════════════════════════════════════════
// USER & AUTH
// ═══════════════════════════════════════════════════

model User {
  id            String        @id @default(uuid())
  email         String        @unique
  name          String?
  role          Role          @default(USER)
  company       String?
  phone         String?
  vatId         String?
  b2bStatus     UserB2BStatus @default(NONE)
  tags          String[]
  internalNotes String?       @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders        Order[]
  addresses     Address[]
  b2bRequests   B2BRequest[]
  quotes        Quote[]
  customerNotes CustomerNote[]
  notifications Notification[]

  @@map("users")
}

enum Role {
  USER
  ADMIN
}

enum UserB2BStatus {
  NONE
  PROSPECT
  ACTIVE
  INACTIVE
}

model Address {
  id         String  @id @default(cuid())
  userId     String
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  label      String?
  street     String
  city       String
  postalCode String
  country    String  @default("DE")
  isDefault  Boolean @default(false)
  orders     Order[]

  @@map("addresses")
}

model CustomerNote {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String   @db.Text
  authorId  String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("customer_notes")
}

// ═══════════════════════════════════════════════════
// PRODUKTE
// ═══════════════════════════════════════════════════

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  imageUrl    String?
  icon        String?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  products    Product[]

  @@map("categories")
}

model Product {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  brand         String
  sku           String?  @unique
  description   String   @db.Text
  specs         Json
  price         Decimal  @db.Decimal(10, 2)
  comparePrice  Decimal? @db.Decimal(10, 2)
  stock         Int      @default(0)
  reservedStock Int      @default(0)
  lowStockAlert Int      @default(5)
  images        String[]
  isActive      Boolean  @default(true)
  isFeatured    Boolean  @default(false)
  tags          String[]
  weight        Float?

  purchasePrice Decimal? @db.Decimal(10, 2)
  supplier      String?
  supplierSku   String?

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  orderItems         OrderItem[]
  quoteItems         QuoteItem[]
  purchaseOrderItems PurchaseOrderItem[]
  stockMovements     StockMovement[]

  // slug and sku are already @unique — @@index not needed for those
  @@index([categoryId])
  @@index([isActive])
  @@map("products")
}

// ═══════════════════════════════════════════════════
// BESTELLUNGEN
// ═══════════════════════════════════════════════════

model Order {
  id                String        @id @default(cuid())
  orderNumber       String        @unique @default(cuid())
  userId            String
  user              User          @relation(fields: [userId], references: [id])
  customerEmail     String        @default("")
  customerName      String?
  shippingAddressId String?
  shippingAddress   Address?      @relation(fields: [shippingAddressId], references: [id])
  shippingSnapshot  Json?
  billingSnapshot   Json?
  subtotal          Decimal       @db.Decimal(10, 2)
  shippingCost      Decimal       @default(0) @db.Decimal(10, 2)
  taxAmount         Decimal       @default(0) @db.Decimal(10, 2)
  totalAmount       Decimal       @db.Decimal(10, 2)
  status            OrderStatus   @default(PENDING)
  paymentStatus     PaymentStatus @default(PENDING)
  stripeSessionId   String?       @unique
  stripePaymentId   String?
  stripeCustomerId  String?
  trackingNumber    String?
  shippingProvider  String?
  notes             String?       @db.Text
  adminNotes        String?       @db.Text
  quoteId           String?

  items    OrderItem[]
  timeline OrderTimeline[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // stripeSessionId is already @unique — @@index not needed for it
  @@index([userId])
  @@index([status])
  @@index([paymentStatus])
  @@index([customerEmail])
  @@map("orders")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product @relation(fields: [productId], references: [id])
  productName String
  productSku  String?
  imageUrl    String?
  unitPrice   Decimal @db.Decimal(10, 2)
  quantity    Int
  totalPrice  Decimal @db.Decimal(10, 2)

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model OrderTimeline {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  event     String
  message   String
  oldValue  String?
  newValue  String?
  createdBy String?
  createdAt DateTime @default(now())

  @@index([orderId])
  @@map("order_timeline")
}

// ═══════════════════════════════════════════════════
// ANGEBOTE / QUOTES
// ═══════════════════════════════════════════════════

model Quote {
  id          String      @id @default(cuid())
  quoteNumber String      @unique @default(cuid())
  status      QuoteStatus @default(DRAFT)

  userId          String?
  user            User?   @relation(fields: [userId], references: [id])
  customerEmail   String
  customerName    String?
  customerCompany String?
  customerVatId   String?
  customerPhone   String?

  b2bRequestId String?

  subtotal    Decimal  @default(0) @db.Decimal(10, 2)
  taxRate     Decimal  @default(0.19) @db.Decimal(5, 4)
  taxAmount   Decimal  @default(0) @db.Decimal(10, 2)
  totalAmount Decimal  @default(0) @db.Decimal(10, 2)
  currency    String   @default("EUR")

  notes      String?   @db.Text
  adminNotes String?   @db.Text
  validUntil DateTime?

  accessToken String @unique @default(cuid())

  items QuoteItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // accessToken is already @unique — @@index not needed for it
  @@index([status])
  @@index([customerEmail])
  @@map("quotes")
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

model QuoteItem {
  id          String   @id @default(cuid())
  quoteId     String
  quote       Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product? @relation(fields: [productId], references: [id])
  productName String
  productSku  String?
  imageUrl    String?
  unitPrice   Decimal  @db.Decimal(10, 2)
  quantity    Int
  totalPrice  Decimal  @db.Decimal(10, 2)
  note        String?

  @@index([quoteId])
  @@map("quote_items")
}

// ═══════════════════════════════════════════════════
// B2B
// ═══════════════════════════════════════════════════

model B2BRequest {
  id          String           @id @default(cuid())
  userId      String?
  user        User?            @relation(fields: [userId], references: [id])
  companyName String
  contactName String
  email       String
  phone       String?
  message     String           @db.Text
  items       Json
  status      B2BRequestStatus @default(OPEN)
  adminNotes  String?          @db.Text
  quoteId     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("b2b_requests")
}

enum B2BRequestStatus {
  OPEN
  IN_REVIEW
  QUOTED
  ACCEPTED
  REJECTED
  CLOSED
}

// ═══════════════════════════════════════════════════
// LIEFERANTEN / SUPPLIER
// ═══════════════════════════════════════════════════

model Supplier {
  id          String   @id @default(cuid())
  name        String   @unique
  contactName String?
  email       String?
  phone       String?
  website     String?
  address     String?  @db.Text
  notes       String?  @db.Text
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  purchaseOrders PurchaseOrder[]

  @@map("suppliers")
}

model PurchaseOrder {
  id          String              @id @default(cuid())
  poNumber    String              @unique @default(cuid())
  supplierId  String
  supplier    Supplier            @relation(fields: [supplierId], references: [id])
  status      PurchaseOrderStatus @default(DRAFT)
  subtotal    Decimal             @default(0) @db.Decimal(10, 2)
  totalAmount Decimal             @default(0) @db.Decimal(10, 2)
  notes       String?             @db.Text
  expectedAt  DateTime?
  receivedAt  DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  items PurchaseOrderItem[]

  @@index([supplierId])
  @@index([status])
  @@map("purchase_orders")
}

enum PurchaseOrderStatus {
  DRAFT
  ORDERED
  PARTIAL
  RECEIVED
  CANCELLED
}

model PurchaseOrderItem {
  id               String        @id @default(cuid())
  purchaseOrderId  String
  purchaseOrder    PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId        String?
  product          Product?      @relation(fields: [productId], references: [id])
  productName      String
  productSku       String?
  unitCost         Decimal       @db.Decimal(10, 2)
  quantity         Int
  quantityReceived Int           @default(0)
  totalCost        Decimal       @db.Decimal(10, 2)

  @@index([purchaseOrderId])
  @@map("purchase_order_items")
}

// ═══════════════════════════════════════════════════
// INVENTORY MOVEMENTS
// ═══════════════════════════════════════════════════

model StockMovement {
  id           String            @id @default(cuid())
  productId    String
  product      Product           @relation(fields: [productId], references: [id])
  type         StockMovementType
  quantity     Int
  balanceAfter Int
  reference    String?
  reason       String?
  createdBy    String?
  createdAt    DateTime          @default(now())

  @@index([productId])
  @@index([createdAt])
  @@map("stock_movements")
}

enum StockMovementType {
  PURCHASE
  SALE
  RETURN
  ADJUSTMENT
  RESERVED
  RELEASED
}

// ═══════════════════════════════════════════════════
// NOTIFICATIONS
// ═══════════════════════════════════════════════════

model Notification {
  id        String           @id @default(cuid())
  userId    String?
  user      User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

enum NotificationType {
  NEW_ORDER
  LOW_STOCK
  NEW_B2B
  QUOTE_ACCEPTED
  QUOTE_REJECTED
  NEW_CUSTOMER
  SYSTEM
}
