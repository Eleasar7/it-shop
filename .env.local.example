# ─── Datenbank (Supabase PostgreSQL) ──────────────────────────────────────
# Pooler-URL für Serverless (Vercel, Next.js API Routes)
DATABASE_URL="postgresql://postgres.[PROJEKT-REF]:[PASSWORT]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direkte Verbindung für Prisma Migrate
DIRECT_URL="postgresql://postgres.[PROJEKT-REF]:[PASSWORT]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# ─── Supabase Auth ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://[PROJEKT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.XXXX"
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.XXXX"

# ─── Stripe ────────────────────────────────────────────────────────────────
# Test-Keys (pk_test_ / sk_test_) für Entwicklung
# Live-Keys (pk_live_ / sk_live_) für Produktion
STRIPE_SECRET_KEY="sk_test_XXXX"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_XXXX"
STRIPE_WEBHOOK_SECRET="whsec_XXXX"

# ─── App ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Für Produktion: NEXT_PUBLIC_APP_URL="https://deine-domain.de"

# ─── Email (Resend.com — https://resend.com) ───────────────────────────────
# Sign up free at resend.com, verify your domain, then add your API key.
# Without this key, emails are logged to the console in dev mode.
RESEND_API_KEY="re_XXXX"

# Sender address (must be verified in Resend)
EMAIL_FROM="noreply@techcore-shop.de"

# Admin notification recipient
EMAIL_ADMIN="admin@techcore-shop.de"

# ─── Internal product fields (no env needed — stored in DB only) ─────────────
# purchasePrice, supplier, supplierSku are admin-only fields stored on Product.
# They are NEVER exposed to the shop frontend.
# Run: npx prisma migrate dev --name add_product_internal_fields
